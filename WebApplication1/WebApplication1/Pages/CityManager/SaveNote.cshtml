@page
@model WebApplication1.Pages.CityManager.SaveNote

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <title></title>
</head>
<body>
<div>
    <form method="post">
        <div>
            <label asp-for="NoteContent.Content">Digite o conteúdo:</label>
            <input asp-for="NoteContent.Content" />
        </div>
        
        <button type="submit">Enviar</button>
    </form>
    
    @if (Model.ArquivoSalvo != null)
    {
        <div>
            <p>Arquivo salvo com sucesso!</p>
            <a href="~/files/@Model.ArquivoSalvo" download>Baixar arquivo</a>
        </div>
    }
</div>
</body>
</html>